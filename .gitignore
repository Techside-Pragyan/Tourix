# ========================================
# Tourix - MERN Stack Project .gitignore
# ========================================

# Dependencies
node_modules/
package-lock.json

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.development
.env.production
.env.staging
.env*.local

# Build outputs
dist/
dist-ssr/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS generated files
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
._*

# Editor / IDE files
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# Coverage & testing
coverage/
*.lcov

# Misc
*.local
*.tgz
.cache/
.temp/
.tmp/

# MongoDB data (if local)
data/db/

# Uploaded files (if using multer)
uploads/
